#!/usr/bin/env bash
# Block push when clippy reports warnings. Stricter than CI's clippy step
# (adds --all-targets so tests/examples/benches are linted too). Does NOT
# duplicate CI's fmt-check/test/build steps — those can still fail in CI.

set -euo pipefail

if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-push: cargo not found in PATH; skipping clippy." >&2
    exit 0
fi

# copad-linux is GTK4/VTE4/webkit — it only builds on Linux (needs pkg-config +
# libsoup/gtk system libs). Off Linux, exclude it so clippy still lints every
# other crate instead of hard-failing on a crate that can't compile here. CI and
# Linux dev machines run the full workspace, so copad-linux is never unlinted.
EXCLUDES=()
if [ "$(uname -s)" != "Linux" ]; then
    EXCLUDES=(--exclude copad-linux)
    echo "pre-push: non-Linux host — excluding copad-linux (GTK) from clippy." >&2
fi

echo "pre-push: running cargo clippy --workspace ${EXCLUDES[*]} --all-targets -- -D warnings" >&2

if ! cargo clippy --workspace "${EXCLUDES[@]}" --all-targets -- -D warnings; then
    echo "" >&2
    echo "pre-push: clippy failed. Fix the warnings above before pushing." >&2
    echo "          (bypass with 'git push --no-verify' if you really must.)" >&2
    exit 1
fi
